# Andromeda Core - Environment Variables Example
# Copy this file to .env and fill in your actual values.
# For production deployment on Vercel, add these variables manually in the Vercel dashboard.
# NEVER commit actual credentials to the repository.

# ============ DATABASE ============
# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority&appName=AndromedaCore
MONGODB_USERNAME=your_mongodb_username
MONGODB_PASSWORD=your_mongodb_password
MONGODB_CLUSTER=your_cluster_name
MONGODB_APP_NAME=AndromedaCore

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# ============ BLOCKCHAIN & WEB3 ============
# Rootstock
ROOTSTOCK_ENABLED=true
ROOTSTOCK_RPC_URL=https://public-node.rsk.co
ROOTSTOCK_RPC_PRIMARY=https://public-node.rsk.co
ROOTSTOCK_RPC_PREMIUM=https://your-premium-rpc.rsk.co
ROOTSTOCK_GOVERNOR_ADDRESS=0x0000000000000000000000000000000000000000
ROOTSTOCK_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
ROOTSTOCK_TIMELOCK_ADDRESS=0x0000000000000000000000000000000000000000
ROOTSTOCK_GRAPHQL_URL=https://api.thegraph.com/subgraphs/name/tally/rootstock-governance
ROOTSTOCK_POLLING_INTERVAL=60000

# Optimism
OPTIMISM_ENABLED=true
OPTIMISM_RPC_URL=https://mainnet.optimism.io
OPTIMISM_GOVERNOR_ADDRESS=0x0000000000000000000000000000000000000000
OPTIMISM_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
OPTIMISM_GRAPHQL_URL=https://api.thegraph.com/subgraphs/name/tally/optimism-governance
OPTIMISM_POLLING_INTERVAL=60000

# Arbitrum
ARBITRUM_ENABLED=true
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_GOVERNOR_ADDRESS=0x0000000000000000000000000000000000000000
ARBITRUM_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
ARBITRUM_GRAPHQL_URL=https://api.thegraph.com/subgraphs/name/tally/arbitrum-governance
ARBITRUM_POLLING_INTERVAL=60000

# Snapshot
SNAPSHOT_API_KEY=your_snapshot_api_key
SNAPSHOT_GOVERNOR_ADDRESS=0x0000000000000000000000000000000000000000
SNAPSHOT_TOKEN_ADDRESS=0x0000000000000000000000000000000000000000
SNAPSHOT_GRAPHQL_URL=https://hub.snapshot.org/graphql
SNAPSHOT_POLLING_INTERVAL=60000

# Algorand
ALGORAND_TREASURY_ADDRESS=your_algorand_treasury_address

# Ethereum
ETHEREUM_RPC_URL=https://mainnet.infura.io/v3/your_infura_project_id

# Vara Network
VARA_ENABLED=true
VARA_MNEMONIC="word1 word2 ... word12"
VARA_NODE_URL=wss://rpc.vara.network
VARA_NETWORK_ENDPOINT=wss://rpc.vara.network
VARA_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
VARA_GAS_LIMIT=1000000000
VARA_SIMULATION_MODE=false

# AVIP (Andromeda Validation & Integrity Protocol)
AVIP_ENABLED=true
AVIP_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
AVIP_RPC_URL=https://mainnet.infura.io/v3/your_infura_project_id
AVIP_PRIVATE_KEY=your_private_key_here
AVIP_NETWORK=mainnet
AVIP_BATCH_SIZE=10
AVIP_MAX_WAIT_TIME=30000

# Polkadot
POLKADOT_WS_URL=wss://rpc.polkadot.io

# ============ APIS & EXTERNAL SERVICES ============
# The Graph - REQUIRED for Rootstock data
THEGRAPH_API_KEY=your_thegraph_api_key_here

# Tally - Used as fallback for Rootstock governance data
TALLY_API_KEY=your_tally_api_key_here
TALLY_API_URL=https://api.tally.xyz/query
TALLY_POLLING_INTERVAL=60000

# Piñata (IPFS)
PINATA_API_KEY=your_pinata_api_key
PINATA_API_SECRET=your_pinata_api_secret
PINATA_JWT=your_pinata_jwt
PINATA_GATEWAY=https://gateway.pinata.cloud

# SendGrid (Email)
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ============ CACHE & MESSAGING ============
# Redis
REDIS_URL=redis://username:password@host:port/database
REDIS_TCP_HOST=localhost
REDIS_TCP_PORT=6379
REDIS_TCP_PASSWORD=your_redis_password

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://your-rest-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# ============ NOTIFICATIONS ============
# Telegram Bots
TELEGRAM_BOT_TOKEN_CORE=your_telegram_bot_token_core
TELEGRAM_BOT_TOKEN_LANDING=your_telegram_bot_token_landing
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
TELEGRAM_TEST_CHAT_ID=your_telegram_test_chat_id

# Discord
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# ============ OBSERVABILITY & MONITORING ============
# Grafana
NEXT_PUBLIC_GRAFANA_FARO_URL=https://faro-collector-prod-eu-central-0.grafana.net/collect/your_collector_id
NEXT_PUBLIC_GRAFANA_FARO_APP_NAME=AndromedaCore
GRAFANA_LOKI_URL=https://logs-prod-039.grafana.net/loki/api/v1/push
GRAFANA_LOKI_USER=your_grafana_user_id
GRAFANA_LOKI_PASS=your_grafana_api_key
GRAFANA_API_KEY=your_grafana_api_key

# ============ DEVELOPMENT & TESTING ============
# Ngrok
NGROK_AUTHTOKEN=your_ngrok_authtoken

# Test Configuration
TEST_EMAIL_RECIPIENT=test@yourdomain.com
ALLOW_INSECURE_SIGNATURES=false
DATA_SYNC_INTERVAL=300000
MAX_CONCURRENT_SYNCS=3

# ============ FRONTEND CONFIGURATION ============
NEXT_PUBLIC_APP_URL=https://your-app-url.com
NEXT_PUBLIC_TREASURY_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_EIP=your_eip_config
NEXT_PUBLIC_RP_ID=your_rp_id
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# ============ SECURITY ============
WALLET_HASH_ALGORITHM=sha256
WALLET_HASH_SALT_LENGTH=32
WALLET_HASH_ROTATION_DAYS=30

# ============ NODE ENVIRONMENT ============
NODE_ENV=development
